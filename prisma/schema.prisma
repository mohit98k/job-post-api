// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

//data models 
enum Role{
  USER
  COMPANY
  GOD
}
model User{
  id Int @id @default(autoincrement())
  fullname String
  userName String @unique
  email String @unique
  password String 
  role Role @default(USER)//this is my custom enum data type 
  company Company?
  refreshToken String?
  applications Application[]//linking application to user 
  createdAt DateTime @default(now())
}
model Company{
  id Int @id @default(autoincrement())//fk of the job table 
  userId Int @unique //actual foreign key col 
  user User  @relation(fields: [userId] , references: [id])//now can access user.fullname via this 
  companyName String 
  websiteLink String? 
  about String 
  location String 
  jobs Job[]//linking the job table 
}


enum Location  {
  REMOTE
  ONSITE
  HYBRID
}
model Job{
  id Int @id @default(autoincrement())//pk of the tabel 
  companyId Int  //fk col
  company Company @relation(fields: [companyId], references: [id])//linking the company table so u can access company
  jobRole String 
  description String 
  location Location @default(ONSITE)
  salary Int?
  experience Int
  applications Application[]//linking job with application
  tags Tag[]
  skills Skill[]
  createdAt DateTime @default(now())

  @@index([jobRole])
 // @@index([location]) this can be obtained from the composite indexing 
  @@index([companyId])
  @@index([createdAt])
  @@index([location,jobRole,createdAt])
}

enum Status{
  APPLIED
  ACCEPTED
  REJECTED 
}
//when was applied ? who applied ? to what job was applied for ?
model Application{
  id Int @id @default(autoincrement())

  userId Int //fk col
  user User @relation(fields: [userId],references: [id])

  jobId Int //fk col
  job Job @relation(fields: [jobId],references: [id])

  status Status @default(APPLIED)
  createdAt DateTime @default(now())


  @@unique([userId, jobId])//thsi works as a composite index internally 
  //@@index([userId]) this one is included in the above by left rule 
  @@index([jobId,createdAt])
  //@@index([jobId])  this one is included in the above by left rule 
}

model Tag{
  id Int @id @default(autoincrement())
  jobs Job[]
  tagValue String @unique
  
}
model Skill{
  id Int @id @default(autoincrement())
  jobs Job[]
  skillName String @unique
}